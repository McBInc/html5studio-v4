# Generated by Unity → HTML5 Studio
# https://unity-html5-studio-v3.vercel.app
# Apache/.htaccess hints for Unity WebGL hosting

# wasm mime
AddType application/wasm .wasm
AddType application/octet-stream .data
AddType application/javascript .js
AddType application/json .json

# Cache Build folder strongly + avoid caching entrypoint
<IfModule mod_headers.c>
  <LocationMatch "^/Build/">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </LocationMatch>
  <LocationMatch "^/$">
    Header set Cache-Control "no-cache"
  </LocationMatch>
  <LocationMatch "^/index\.html$">
    Header set Cache-Control "no-cache"
  </LocationMatch>
  # Helps proxies/CDNs treat compressed/uncompressed variants correctly
  Header append Vary "Accept-Encoding"
</IfModule>
