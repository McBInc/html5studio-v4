{
  "compilerOptions": {
    "target": "ES2022",

    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],

    // Enable Node globals like process
    "types": ["node"],

    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,

    "esModuleInterop": true,

    "module": "esnext",
    "moduleResolution": "bundler",

    "resolveJsonModule": true,
    "isolatedModules": true,

    "jsx": "react-jsx",

    "incremental": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["./src/*"]
    },

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}
